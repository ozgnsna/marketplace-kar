{
  "name": "marketplace-kar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"const fs=require('fs');['.next','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\" && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "generate:commission": "node scripts/parse-commission-pdfs.mjs",
